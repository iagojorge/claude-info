{
  "buildCommand": "npm install",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/api/payment/(.*)",
      "destination": "/api/payment.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/ads/(.*)",
      "destination": "/ads/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/server.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/payment.js": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
